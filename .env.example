# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/bonglem

# Server port
PORT=3000

# CORS origin (frontend URL)
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Email configuration (for order confirmation emails)
# For Gmail: Enable "App Passwords" in Google Account settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Admin email (receives notifications for new orders)
ADMIN_EMAIL=admin@example.com

# PAYOS
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_WEBHOOK_URL=http://localhost:3000/api/orders/payos/webhook
